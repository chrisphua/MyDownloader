# Copy to apps/desktop/.env for local development.
# VITE_* variables are inlined into the renderer bundle at build time.
# Do NOT put secrets here — they are visible in the client bundle.
#
# Local dev server (apps/api running against DynamoDB Local):
VITE_API_URL=http://localhost:3000

# Deployed AWS API:
# VITE_API_URL=https://abc123.execute-api.ap-southeast-1.amazonaws.com

# Cognito (from CDK outputs or AWS Console):
VITE_USER_POOL_ID=ap-southeast-1_XXXXXXXXX
VITE_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
