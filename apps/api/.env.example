# Copy to apps/api/.env for local development.
# These are used by the Express dev server (dev-server.ts) and bootstrap script.
# Lambda gets these from CDK at deploy time — no .env needed in production.

# DynamoDB Local table name
TODOS_TABLE_NAME=todos-local

# DynamoDB Local endpoint (Docker container)
DYNAMODB_ENDPOINT=http://localhost:8000

# AWS region (any value works against DynamoDB Local)
AWS_REGION=us-east-1
