# Copy to apps/mobile/.env for local development.
#
# EXPO_PUBLIC_* variables are inlined into the JS bundle at build time.
# Do NOT put secrets here — they are visible in the client bundle.
#
# For iOS Simulator: localhost works fine.
# For Android Emulator: use your Mac's LAN IP (e.g. http://192.168.1.42:3000).
# For physical device: same as Android — use your LAN IP.
EXPO_PUBLIC_API_URL=http://localhost:3000
