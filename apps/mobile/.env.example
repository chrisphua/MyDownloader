# Copy to apps/mobile/.env for local development.
#
# EXPO_PUBLIC_* variables are inlined into the JS bundle at build time and
# are visible in the client. Do NOT put secrets here.
#
# Local API (dev-server.ts running against DynamoDB Local):
EXPO_PUBLIC_API_URL=http://localhost:3000

# When pointing at a deployed environment, replace with the CDK output:
# EXPO_PUBLIC_API_URL=https://abc123.execute-api.us-east-1.amazonaws.com
