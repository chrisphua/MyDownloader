{
  "name": "todo-app",
  "private": true,
  "version": "0.1.0",
  "description": "Cross-platform CRUD todo app: Expo (iOS/Android/Web) + AWS serverless backend",
  "workspaces": [
    "packages/*",
    "apps/*",
    "infra"
  ],
  "scripts": {
    "build:types": "npm run build --workspace @todo-app/types",
    "lint": "npm run lint --workspaces --if-present",
    "lint:eslint": "eslint .",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "expo": "~55.0.23"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "expo": "~55.0.23",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.2"
  }
}
